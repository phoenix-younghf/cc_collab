{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "summary",
    "decisions",
    "changed_files",
    "verification",
    "open_questions",
    "risks",
    "follow_up_suggestions",
    "agent_usage",
    "terminal_state",
    "runtime_mode",
    "artifact_type",
    "capability_summary",
    "degradation_notes"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "summary": {"type": "string"},
    "decisions": {"type": "array", "items": {"type": "string"}},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "verification": {
      "type": "object",
      "required": ["commands_run", "results", "all_passed"],
      "properties": {
        "commands_run": {"type": "array", "items": {"type": "string"}},
        "results": {"type": "array", "items": {"type": "string"}},
        "all_passed": {"type": "boolean"}
      }
    },
    "open_questions": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}},
    "follow_up_suggestions": {"type": "array", "items": {"type": "string"}},
    "agent_usage": {
      "type": "object",
      "required": ["used_subagents", "notes"],
      "properties": {
        "used_subagents": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    },
    "terminal_state": {
      "type": "string",
      "enum": [
        "archived",
        "integrated",
        "commit-ready",
        "patch-ready",
        "discarded",
        "inspection-required"
      ]
    },
    "runtime_mode": {
      "type": "string",
      "enum": ["git-aware", "filesystem-only"]
    },
    "artifact_type": {
      "type": "string",
      "enum": ["none", "git-patch", "file-change-set"]
    },
    "capability_summary": {
      "type": "object"
    },
    "degradation_notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "remediation": {"type": "string"},
    "patch_path": {"type": "string"},
    "apply_command": {"type": "string"},
    "change_set_manifest": {"type": "object"}
  }
}
