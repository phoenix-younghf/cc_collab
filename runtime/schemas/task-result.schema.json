{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "summary",
    "decisions",
    "changed_files",
    "verification",
    "open_questions",
    "risks",
    "follow_up_suggestions",
    "agent_usage",
    "terminal_state"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "terminal_state": {
      "type": "string",
      "enum": [
        "archived",
        "integrated",
        "commit-ready",
        "patch-ready",
        "discarded",
        "inspection-required"
      ]
    }
  }
}
