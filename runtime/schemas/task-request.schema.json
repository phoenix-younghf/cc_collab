{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "task_type",
    "execution_mode",
    "write_policy",
    "origin",
    "workdir",
    "objective",
    "context_summary",
    "inputs",
    "claude_role"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "task_type": {
      "type": "string",
      "enum": ["research", "review", "design-review", "plan-review", "implementation"]
    },
    "execution_mode": {
      "type": "string",
      "enum": ["single-worker", "multi-agent"]
    },
    "write_policy": {
      "type": "string",
      "enum": ["read-only", "write-in-place", "write-isolated"]
    }
  }
}
