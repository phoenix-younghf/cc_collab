#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${CCOLLAB_RUNTIME_ROOT:-}" ]]; then
  ROOT="$CCOLLAB_RUNTIME_ROOT"
else
  SOURCE="${BASH_SOURCE[0]}"
  while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
  done
  ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
fi

python_works() {
  local candidate="$1"
  command -v "$candidate" >/dev/null 2>&1 || return 1
  "$candidate" -c "import sys; raise SystemExit(0 if sys.version_info >= (3, 9) else 1)" \
    >/dev/null 2>&1
}

PYTHON=""
for candidate in python3 python; do
  if python_works "$candidate"; then
    PYTHON="$candidate"
    break
  fi
done

if [[ -z "$PYTHON" ]]; then
  echo "Unable to find Python 3.9+. Install Python 3.9 or newer and ensure python3 or python is on PATH." >&2
  exit 1
fi

export PYTHONPATH="$ROOT${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON" -m runtime.cli "$@"
