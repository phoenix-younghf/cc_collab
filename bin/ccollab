#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${CCOLLAB_RUNTIME_ROOT:-}" ]]; then
  ROOT="$CCOLLAB_RUNTIME_ROOT"
else
  ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

PYTHON=""
for candidate in python3 python; do
  if command -v "$candidate" >/dev/null 2>&1; then
    PYTHON="$candidate"
    break
  fi
done

if [[ -z "$PYTHON" ]]; then
  echo "Unable to find Python. Install Python 3 and ensure python3 or python is on PATH." >&2
  exit 1
fi

export PYTHONPATH="$ROOT${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON" -m runtime.cli "$@"
